import javax.imageio.ImageIO;
import javax.swing.*;
import java.awt.*;
import java.awt.image.BufferedImage;
import java.io.File;
import java.io.IOException;

public class ManualEdgeDetection {

    public static void main(String[] args) {
        // 1. 檔案選擇
        JFileChooser fileChooser = new JFileChooser();
        if (fileChooser.showOpenDialog(null) != JFileChooser.APPROVE_OPTION) return;
        
        try {
            File inputFile = fileChooser.getSelectedFile();
            BufferedImage original = ImageIO.read(inputFile);

            // 2. 轉灰階
            BufferedImage grayImg = toGrayScale(original);

            // 3. 計算偏微分與梯度 (手動實作投影片概念)
            BufferedImage edgeImg = computeGradients(grayImg, 50); // 50 是閥值

            // 4. 顯示結果
            showResult(original, edgeImg);

        } catch (IOException e) {
            e.printStackTrace();
        }
    }

    // 模擬投影片：計算影像梯度
    private static BufferedImage computeGradients(BufferedImage gray, int threshold) {
        int w = gray.getWidth();
        int h = gray.getHeight();
        BufferedImage result = new BufferedImage(w, h, BufferedImage.TYPE_INT_RGB);

        for (int y = 0; y < h - 1; y++) {
            for (int x = 0; x < w - 1; x++) {
                // 取得當前點與鄰近點的亮度 (0-255)
                int current = new Color(gray.getRGB(x, y)).getRed();
                int right = new Color(gray.getRGB(x + 1, y)).getRed();
                int bottom = new Color(gray.getRGB(x, y + 1)).getRed();

                // 計算偏微分 (Finite Differences)
                // dx = f(x+1, y) - f(x, y)  --> 垂直邊緣
                // dy = f(x, y+1) - f(x, y)  --> 水平邊緣
                int dx = right - current;
                int dy = bottom - current;

                // 計算梯度強度 (Magnitude)
                double magnitude = Math.sqrt(dx * dx + dy * dy);

                // 二值化：超過閥值就畫白點 (邊緣)，否則黑點
                if (magnitude > threshold) {
                    result.setRGB(x, y, Color.WHITE.getRGB());
                } else {
                    result.setRGB(x, y, Color.BLACK.getRGB());
                }
            }
        }
        return result;
    }

    private static BufferedImage toGrayScale(BufferedImage src) {
        BufferedImage gray = new BufferedImage(src.getWidth(), src.getHeight(), BufferedImage.TYPE_BYTE_GRAY);
        Graphics g = gray.getGraphics();
        g.drawImage(src, 0, 0, null);
        g.dispose();
        return gray;
    }

    private static void showResult(BufferedImage img1, BufferedImage img2) {
        JFrame frame = new JFrame("手動邊緣偵測 (無 OpenCV)");
        frame.setLayout(new FlowLayout());
        frame.add(new JLabel(new ImageIcon(img1)));
        frame.add(new JLabel(new ImageIcon(img2)));
        frame.pack();
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setVisible(true);
    }
}
